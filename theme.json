{
	"version": 2,
	"title": "UGA Bold",
	"customTemplates": [
		{
			"name": "single-no-sidebar",
			"title": "Post without sidebar",
			"postTypes": [
				"post"
			]
		},
		{
			"name": "page-with-sidebar",
			"title": "Page with sidebar",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-blank",
			"title": "Blank",
			"postTypes": [
				"page"
			]
		}
	],
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		},
		{
			"name": "sidebar",
			"title": "Sidebar",
			"area": "uncategorized"
		}
	],
	"settings": {
		"custom": {
			"spacing": {
				"baseline": "2rem",
				"two-thirds-baseline": "1.3rem",
				"four-fifths-baseline": "1.6rem",
				"half-baseline": "1rem",
				"third-baseline": "0.66rem",
				"fourth-baseline": "0.5rem",
				"double-baseline": "4rem"
			},
			"shadow": {
				"hover-small": "0 0 3px rgb(0 0 0 / 30%)",
				"hover-large": "0 0 10px rgb(0 0 0 / 30%)"
			},
			"transition": {
				"box-hover": "box-shadow 200ms ease"
			},
			"radius": {
				"small-round": "3px"
			}
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"customGradient": false,
			"customDuotone": false,
			"link": true,
			"palette": [
				{
					"slug": "primary",
					"color": "#ba0c2f",
					"name": "Primary"
				},
				{
					"slug": "secondary",
					"color": "#00a3ad",
					"name": "Secondary"
				},
				{
					"slug": "tertiary",
					"color": "#c8d8eb",
					"name": "Tertiary"
				},
				{
					"slug": "base",
					"color": "#ffffff",
					"name": "Base"
				},
				{
					"slug": "base-two",
					"color": "#eaeaea",
					"name": "Base 2"
				},
				{
					"slug": "contrast",
					"color": "#000000",
					"name": "Contrast"
				},
				{
					"slug": "contrast-two",
					"color": "#333333",
					"name": "Contrast 2"
				}
			]
		},
		"appearanceTools": true,
		"typography": {
			"fluid": true,
			"dropCap": false,
			"customFontSize": false,
			"fontFamilies": [
				{
					"fontFamily": "\"Merriweather Sans\",Georgia,Helvetica, Arial, Sans-Serif",
					"name": "\"Merriweather Sans\"",
					"slug": "merriweather-sans",
					"fontFace": [
						{
							"fontFamily": "\"Merriweather Sans\"",
							"fontWeight": "400",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"src": [
								"file:./assets/fonts/merriweather-sans-v22-latin-regular.woff2"
							]
						},
						{
							"fontFamily": "\"Merriweather Sans\"",
							"fontWeight": "700",
							"fontStretch": "normal",
							"fontStyle": "bold",
							"src": [
								"file:./assets/fonts/merriweather-sans-v22-latin-700.woff2"
							]
						},
						{
							"fontFamily": "\"Merriweather Sans\"",
							"fontWeight": "400",
							"fontStretch": "normal",
							"fontStyle": "italic",
							"src": [
								"file:./assets/fonts/merriweather-sans-v22-latin-italic.woff2"
							]
						},
						{
							"fontFamily": "\"Merriweather Sans\"",
							"fontWeight": "700",
							"fontStretch": "normal",
							"fontStyle": "italic",
							"src": [
								"file:./assets/fonts/merriweather-sans-v22-latin-700italic.woff2"
							]
						}
					]
				},
				{
					"name": "Oswald",
					"slug": "oswald",
					"fontFamily": "Oswald, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Oswald",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": [
								"file:./assets/fonts/oswald-v49-latin-regular.woff2"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "tiny",
					"name": "Tiny",
					"size": "0.75rem",
					"fluid": {
						"min": "0.75rem",
						"max": "0.75rem"
					}
				},
				{
					"slug": "small",
					"name": "Small",
					"size": "0.85rem",
					"fluid": {
						"min": "0.85rem",
						"max": "0.85rem"
					}
				},
				{
					"slug": "normal",
					"name": "Normal",
					"size": "1rem",
					"fluid": {
						"min": "1rem",
						"max": "1rem"
					}
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "1.2rem",
					"fluid": {
						"min": "1.13rem",
						"max": "1.2rem"
					}
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "1.44rem",
					"fluid": {
						"min": "1.27rem",
						"max": "1.44rem"
					}
				},
				{
					"slug": "x-large",
					"name": "Extra Large",
					"size": "1.73rem",
					"fluid": {
						"min": "1.42rem",
						"max": "1.73rem"
					}
				},
				{
					"slug": "huge",
					"name": "Huge",
					"size": "2.07rem",
					"fluid": {
						"min": "1.6rem",
						"max": "2.07rem"
					}
				},
				{
					"slug": "gigantic",
					"name": "Gigantic",
					"size": "2.49rem",
					"fluid": {
						"min": "1.8rem",
						"max": "2.49rem"
					}
				}
			]
		},
		"layout": {
			"contentSize": "960px",
			"wideSize": "1100px"
		}
	},
	"styles": {
		"color": {
			"text": "var(--wp--preset--color--contrast-two)"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				}
			},
			"button": {
				":hover": {
					"shadow": "var(--wp--custom--shadow--hover-large)"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--gigantic)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--huge)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--normal)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--merriweather-sans)",
			"fontSize": "var(--wp--preset--font-size--normal)",
			"lineHeight": "1.75",
			"fontWeight": "normal",
			"fontStyle": "normal"
		},
		"spacing": {
			"blockGap": "var(--wp--custom--spacing--baseline)"
		},
		"blocks": {
			"core/buttons": {
				"spacing": {
					"blockGap": "var(--wp--custom--spacing--third-baseline)"
				}
			},
			"core/button": {
				"border": {
					"radius": "var(--wp--custom--radius--small-round)"
				},
				"color": {
					"background": "var(--wp--preset--color--primary)"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--custom--spacing--third-baseline)",
						"right": "var(--wp--custom--spacing--two-thirds-baseline)",
						"bottom": "var(--wp--custom--spacing--third-baseline)",
						"left": "var(--wp--custom--spacing--two-thirds-baseline)"
					}
				}
			},
			"core/cover": {
				"spacing": {
					"padding": "var(--wp--custom--spacing--baseline)"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--base-two)",
					"background": "var(--wp--preset--color--base-two)"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "400"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/query-pagination": {
				"elements": {
					"link": {
						"border": {
							"radius": "var(--wp--custom--radius--small-round)"
						},
						"color": {
							"background": "var(--wp--preset--color--base-two)"
						},
						"spacing": {
							"padding": {
								"top": "var(--wp--custom--spacing--third-baseline)",
								"bottom": "var(--wp--custom--spacing--third-baseline)",
								"left": "var(--wp--custom--spacing--third-baseline)",
								"right": "var(--wp--custom--spacing--third-baseline)"
							},
							"margin": {
								"left": "var(--wp--custom--spacing--third-baseline)",
								"right": "var(--wp--custom--spacing--third-baseline)"
							}
						}
					}
				}
			},
			"core/post-excerpt": {
				"elements": {
					"link": {
						"color": {
							"text":"var(--wp--preset--color--base)",
							"background": "var(--wp--preset--color--primary)"
						},
						"border": {
							"radius": "var(--wp--custom--radius--small-round)"
						},
						"spacing": {
							"padding": {
								"top": "var(--wp--custom--spacing--third-baseline)",
								"right": "var(--wp--custom--spacing--third-baseline)",
								"bottom": "var(--wp--custom--spacing--third-baseline)",
								"left": "var(--wp--custom--spacing--third-baseline)"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/read-more": {
				"border": {
					"radius": "var(--wp--custom--radius--small-round)"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--custom--spacing--third-baseline)",
						"right": "var(--wp--custom--spacing--two-thirds-baseline)",
						"bottom": "var(--wp--custom--spacing--third-baseline)",
						"left": "var(--wp--custom--spacing--two-thirds-baseline)"
					}
				}
			}
		}
	}
}