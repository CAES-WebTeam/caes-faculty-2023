{
	"version": 2,
	"customTemplates": [
		{
			"name": "single-no-sidebar",
			"title": "Post without sidebar",
			"postTypes": [
				"post"
			]
		},
		{
			"name": "page-with-sidebar",
			"title": "Page with sidebar",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-blank",
			"title": "Blank",
			"postTypes": [
				"page"
			]
		}
	],
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		},
		{
			"name": "sidebar",
			"title": "Sidebar",
			"area": "uncategorized"
		}
	],
	"settings": {
		"custom": {
			"spacing": {
				"baseline": "2rem",
				"two-thirds-baseline": "1.5rem",
				"four-fifths-baseline": "0.8rem",
				"half-baseline": "0.75rem",
				"third-baseline": "0.5rem",
				"fourth-baseline": "0.375rem",
				"double-baseline": "4rem"
			}
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"customGradient": false,
			"customDuotone": false,
			"link": true,
			"palette": [
				{
					"slug": "primary",
					"color": "#ba0c2f",
					"name": "Primary"
				},
				{
					"slug": "secondary",
					"color": "#00a3ad",
					"name": "Secondary"
				},
				{
					"slug": "tertiary",
					"color": "#c8d8eb",
					"name": "Tertiary"
				},
				{
					"slug": "background",
					"color": "#ffffff",
					"name": "Background"
				},
				{
					"slug": "background-two",
					"color": "#eaeaea",
					"name": "Background 2"
				},
				{
					"slug": "foreground",
					"color": "#000000",
					"name": "Foreground"
				},
				{
					"slug": "foreground-two",
					"color": "#333333",
					"name": "Foreground 2"
				}
			]
		},
		"appearanceTools": true,
		"typography": {
			"dropCap": false,
			"fontFamilies": [
				{
					"name": "System",
					"slug": "system",
					"fontFamily": "-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Oxygen-Sans,Ubuntu,Cantarell,\"Helvetica Neue\",sans-serif"
				},
				{
					"name": "Monospace",
					"slug": "monospace",
					"fontFamily": "Consolas,Menlo,Monaco,\"SF Mono\",\"DejaVu Sans Mono\",\"Roboto Mono\",\"Courier New\",Courier,monospace"
				},
				{
					"fontFamily": "\"Merriweather Sans\",Georgia,Helvetica, Arial, Sans-Serif",
					"name": "\"Merriweather Sans\"",
					"slug": "merriweather-sans",
					"fontFace": [
						{
							"fontFamily": "\"Merriweather Sans\"",
							"fontWeight": "400",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"src": [
								"file:./assets/fonts/merriweather-sans-v22-latin-regular.woff2"
							]
						},
						{
							"fontFamily": "\"Merriweather Sans\"",
							"fontWeight": "700",
							"fontStretch": "normal",
							"fontStyle": "bold",
							"src": [
								"file:./assets/fonts/merriweather-sans-v22-latin-700.woff2"
							]
						},
						{
							"fontFamily": "\"Merriweather Sans\"",
							"fontWeight": "400",
							"fontStretch": "normal",
							"fontStyle": "italic",
							"src": [
								"file:./assets/fonts/merriweather-sans-v22-latin-italic.woff2"
							]
						},
						{
							"fontFamily": "\"Merriweather Sans\"",
							"fontWeight": "700",
							"fontStretch": "normal",
							"fontStyle": "italic",
							"src": [
								"file:./assets/fonts/merriweather-sans-v22-latin-700italic.woff2"
							]
						}
					]
				},
				{
					"name": "Oswald",
					"slug": "oswald",
					"fontFamily": "Oswald, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Oswald",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": [
								"file:./assets/fonts/oswald-v49-latin-regular.woff2"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "tiny",
					"name": "Tiny",
					"size": "0.7rem"
				},
				{
					"slug": "small",
					"name": "Small",
					"size": "0.8rem"
				},
				{
					"slug": "normal",
					"name": "Normal",
					"size": "clamp(1rem, 0vw + 1rem, 1rem)"
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "clamp(1.13rem, 0.17vw + 1.08rem, 1.2rem)"
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "clamp(1.27rem, 0.4vw + 1.17rem, 1.44rem)"
				},
				{
					"slug": "x-large",
					"name": "Extra Large",
					"size": "clamp(1.42rem, 0.7vw + 1.25rem, 1.73rem)"
				},
				{
					"slug": "huge",
					"name": "Huge",
					"size": "clamp(1.6rem, 1.08vw + 1.33rem, 2.07rem)"
				},
				{
					"slug": "gigantic",
					"name": "Gigantic",
					"size": "clamp(1.8rem, 1.57vw + 1.41rem, 2.49rem)"
				}
			]
		},
		"layout": {
			"contentSize": "700px",
			"wideSize": "1000px"
		}
	},
	"styles": {
		"color": {
			"text": "var(--wp--preset--color--foreground-two)"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--gigantic)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--huge)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--normal)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--merriweather-sans)",
			"fontSize": "var(--wp--preset--font-size--normal)",
			"lineHeight": "1.75",
			"fontWeight": "normal",
			"fontStyle": "normal"
		},
		"spacing": {
			"blockGap": "var(--wp--custom--spacing--baseline)"
		},
		"blocks": {
			"core/buttons": {
				"spacing": {
					"blockGap": "var(--wp--custom--spacing--third-baseline)"
				}
			},
			"core/button": {
				"border": {
					"radius": "3px"
				},
				"color": {
					"background": "var(--wp--preset--color--primary)"
				}
			},
			"core/cover": {
				"spacing": {
					"padding": "var(--wp--custom--spacing--baseline)"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--background-two)",
					"background": "var(--wp--preset--color--background-two)"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--oswald)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "400"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/query-pagination": {
				"elements": {
					"link": {
						"border": {
							"radius": "3px"
						},
						"color": {
							"background": "var(--wp--preset--color--background-two)"
						},
						"spacing": {
							"padding": {
								"top": "var(--wp--custom--spacing--third-baseline)",
								"bottom": "var(--wp--custom--spacing--third-baseline)",
								"left": "var(--wp--custom--spacing--third-baseline)",
								"right": "var(--wp--custom--spacing--third-baseline)"
							},
							"margin": {
								"left": "var(--wp--custom--spacing--third-baseline)",
								"right": "var(--wp--custom--spacing--third-baseline)"
							}
						}
					}
				}
			}
		}
	}
}