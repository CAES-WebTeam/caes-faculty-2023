{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "uga-caes/tribe-events-display-date",
	"version": "1.0.2",
	"title": "Event Date (The Event Calendar)",
	"category": "widgets",
	"icon": "calendar-alt",
	"description": "Displays an event's date.",
	"usesContext": [ "postId", "postType", "queryId" ],
	"attributes": {
		"align": {
			"type": "string",
			"default": "left"
		}
	},
	"supports": {
		"alignText": true
	},
	"textdomain": "tribe-events-display-date",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}